# ==================== 生产环境变量 ====================
NODE_ENV=production

# ==================== 应用 ====================
APP_NAME=易算
APP_URL=https://yisuan.com
NEXT_PUBLIC_APP_URL=https://yisuan.com
NEXT_PUBLIC_API_URL=https://api.yisuan.com

# ==================== 数据库 ====================
DATABASE_URL=postgresql://yisuan:CHANGE_ME_PASSWORD@localhost:5432/yisuan
REDIS_URL=redis://localhost:6379

# ==================== JWT ====================
# 生成命令: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_JWT_SECRET_256_BITS_MINIMUM
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_256_BITS_MINIMUM

# ==================== AI (可选) ====================
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ==================== 邮件 ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@yisuan.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD

# ==================== 日志 ====================
LOG_LEVEL=info

# ==================== 监控 ====================
SENTRY_DSN=

# ==================== 验证 ====================
GOOGLE_VERIFICATION=
